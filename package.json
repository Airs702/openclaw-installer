{
  "name": "openclaw-installer",
  "version": "1.2.0",
  "author": "Internal",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.internal.openclaw-installer",
    "productName": "OpenClaw-Installer",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "scripts/**",
      "build/**"
    ],
    "extraResources": [
      {
        "from": "scripts/",
        "to": "scripts/",
        "filter": ["**/*"]
      },
      {
        "from": "bundled-zh/",
        "to": "bundled-zh/",
        "filter": ["**/*"]
      },
      {
        "from": "bundled-official/",
        "to": "bundled-official/",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "installerLanguages": [
        "zh_CN"
      ],
      "language": "2052",
      "include": "build/installer.nsh"
    },
    "dmg": {
      "title": "OpenClaw 安装器"
    }
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "ssh2": "^1.17.0"
  }
}
